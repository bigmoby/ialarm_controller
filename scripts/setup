#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

if [ ! -n "$VIRTUAL_ENV" ]; then
  if [ -x "$(command -v uv)" ]; then
    uv venv venv
  else
    if [ -x "$(command -v python3.14)" ]; then
      python3.14 -m venv venv
    else
      echo "ERROR: python3.14 non trovato. Questo progetto richiede Python >= 3.14.2." >&2
      echo "Installa Python 3.14 e riesegui ./scripts/setup" >&2
      exit 1
    fi
  fi
  source venv/bin/activate
  python -m ensurepip --upgrade
fi

if ! [ -x "$(command -v uv)" ]; then
  python -m pip install uv
fi

python -m pip --disable-pip-version-check install -r requirements.txt
python -m pip --disable-pip-version-check install -r requirements.test.txt

pre-commit install
